# Avelio Credit Frontend - Environment Variables

# ===================================
# API Configuration
# ===================================

# Backend API URL
# For local development, use: http://localhost:5001/api/v1
# For production on Render, use: https://avelio-credit.onrender.com/api/v1
REACT_APP_API_URL=https://avelio-credit.onrender.com/api/v1

# Node environment (development, production, test)
NODE_ENV=production

# ===================================
# Optional Configuration
# ===================================

# App version (for display purposes)
REACT_APP_VERSION=1.0.0

# Enable debug logging (true/false)
REACT_APP_DEBUG=false
