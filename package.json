{
  "name": "avelio-credit",
  "version": "1.0.0",
  "description": "Avelio Credit Management System",
  "private": true,
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "install:backend": "cd avelio-backend && npm install",
    "install:frontend": "cd avelio-frontend && npm install",
    "build:frontend": "cd avelio-frontend && npm run build",
    "postinstall": "npm run install:backend && npm run install:frontend && npm run build:frontend",
    "start": "node avelio-backend/src/server.js",
    "dev:backend": "cd avelio-backend && npm run dev",
    "dev:frontend": "cd avelio-frontend && npm start"
  }
}